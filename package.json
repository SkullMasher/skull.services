    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "1.0.1",
    "@nuxt/test-utils": "4.0.2",
    "@nuxtjs/seo": "^5.1.3",
    "@tailwindcss/vite": "^4.2.4",
    "@types/nodemailer": "^8.0.0",
    "@unhead/vue": "^3.0.4",
    "@vueuse/nuxt": "14.2.1",
    "nodemailer": "^8.0.5",
    "nuxt": "^4.4.2",
    "nuxt-security": "2.5.1",
    "nuxt-svgo": "4.2.6",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
