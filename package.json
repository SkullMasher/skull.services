    "@vue/test-utils": "^2.4.6",
    "daisyui": "^5.5.19",
    "eslint": "^10.2.1",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-tailwindcss": "npm:@hyoban/eslint-plugin-tailwindcss@4.0.0-alpha.12",
    "happy-dom": "^20.9.0",
    "playwright-core": "^1.59.1",
    "vitest": "^4.1.5"
